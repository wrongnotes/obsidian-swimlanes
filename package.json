{
    "name": "wrongnotes-swimlanes",
    "version": "0.1.0",
    "description": "Kanban swimlane board view for Obsidian Bases.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "prepare": "husky",
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "jiti scripts/version-bump.ts && git add manifest.json versions.json",
        "format": "eslint . --fix && prettier --write .",
        "lint": "eslint .",
        "test": "jest",
        "install-plugin": "jiti scripts/install-plugin.ts"
    },
    "keywords": [],
    "license": "0-BSD",
    "devDependencies": {
        "@eslint/js": "9.30.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^16.11.6",
        "dotenv": "^17.3.1",
        "esbuild": "0.25.5",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-obsidianmd": "0.1.9",
        "globals": "14.0.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jiti": "2.6.1",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.0",
        "ts-node": "^10.9.2",
        "tslib": "2.4.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "8.35.1"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}
